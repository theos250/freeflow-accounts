// Deterministic first-pass expense categorizer. Runs entirely client/server-side
// with no network call, so it's fast, free, and testable. Anything it can't
// match with reasonable confidence is left for the LLM fallback (or the user).

export const CATEGORIES = [
  "Meals", "Travel", "Software", "Office", "Utilities", "Marketing",
  "Equipment", "Payroll", "Rent", "Professional Services", "Other",
] as const;

export type Category = (typeof CATEGORIES)[number];
export type Confidence = "high" | "medium" | "low";

export type CategorySuggestion = {
  category: Category;
  confidence: Confidence;
  reason: string;
};

type Rule = { category: Category; confidence: Confidence; patterns: RegExp[] };

// Patterns are matched against "<vendor> <description>" lowercased.
// Longer/more specific pattern lists go first so a specific match (e.g. a named
// cloud vendor) wins over a generic one.
const RULES: Rule[] = [
  {
    category: "Software",
    confidence: "high",
    patterns: [
      /\baws\b|amazon web services/, /google cloud|gcp\b/, /microsoft azure/,
      /\bslack\b/, /\bzoom\b/, /notion/, /\bfigma\b/, /github/, /netflix/,
      /adobe/, /dropbox/, /\bopenai\b/, /anthropic/, /\bvercel\b/, /supabase/,
      /quickbooks/, /canva/, /mailchimp/, /hubspot/, /zapier/, /calendly/,
      /\bsaas\b|subscription (fee|renewal)|software licen[cs]e/,
    ],
  },
  {
    category: "Travel",
    confidence: "high",
    patterns: [
      /\buber\b/, /\blyft\b/, /\btaxi\b|\bcab fare\b/, /\bairbnb\b/,
      /\bhotel\b|\binn\b|\bmarriott\b|\bhilton\b/, /\bairlines?\b|\bairways\b|\bflight\b/,
      /\bfuel\b|\bpetrol\b|\bgas station\b/, /\bparking\b/, /\bboda\b|\bmoto\b/, // East African ride-hailing/motorbike-taxi slang
      /\bvisa fee\b|\bimmigration\b/,
    ],
  },
  {
    category: "Meals",
    confidence: "high",
    patterns: [
      /\brestaurant\b/, /\bcafe\b|\bcoffee\b/, /\bcatering\b/, /\blunch\b|\bdinner\b|\bbreakfast\b/,
      /\bstarbucks\b/, /\bkfc\b/, /\bjava house\b/,
    ],
  },
  {
    category: "Utilities",
    confidence: "high",
    patterns: [
      /\belectricity\b|\bpower bill\b|\breg\b.*(electric|power)/, /\bwater (bill|utility)\b|\bwasac\b/,
      /\binternet\b|\bbroadband\b|\bfiber\b|\bmtn\b|\bairtel\b|\bwifi\b/,
      /\bphone bill\b|\bmobile plan\b/,
    ],
  },
  {
    category: "Marketing",
    confidence: "high",
    patterns: [
      /\bfacebook ads?\b|\bmeta ads?\b/, /\bgoogle ads?\b|\badwords\b/, /\binstagram (ads?|promotion)\b/,
      /\btiktok ads?\b/, /\bbillboard\b/, /\bsponsorship\b/, /\bprinting.*flyers?\b|\bflyers?\b/,
      /\bsem\b|\bseo\b service/,
    ],
  },
  {
    category: "Rent",
    confidence: "high",
    patterns: [/\boffice rent\b|\bwarehouse rent\b|\bshop rent\b|\bmonthly rent\b|\blease payment\b/],
  },
  {
    category: "Payroll",
    confidence: "high",
    patterns: [/\bpayroll\b|\bsalar(y|ies)\b|\bwages\b|\bstaff pay\b/],
  },
  {
    category: "Equipment",
    confidence: "high",
    patterns: [
      /\blaptop\b|\bdesktop\b|\bmonitor\b|\bprinter\b|\bcomputer\b/,
      /\bfurniture\b|\bdesk\b|\bchair\b/, /\bmachinery\b|\bequipment purchase\b/,
    ],
  },
  {
    category: "Professional Services",
    confidence: "high",
    patterns: [
      /\blaw firm\b|\blegal fees?\b|\battorney\b|\blawyer\b/, /\baccounting fees?\b|\bauditor?\b|\bbookkeeping\b/,
      /\bconsult(ant|ing)\b/, /\bupwork\b|\bfiverr\b|\bfreelance(r)?\b/, /\bnotary\b/,
    ],
  },
];

// Amount/description signals that should always be flagged for a human even if a
// vendor match is found — e.g. refunds are the opposite economic event and are
// easy to double count, and very large or oddly split amounts warrant a look.
function ambiguitySignals(description: string, amount: number): string[] {
  const flags: string[] = [];
  const d = description.toLowerCase();
  if (amount < 0) flags.push("negative amount (likely a refund or credit — verify direction)");
  if (/\brefund\b|\bcredit note\b|\breversal\b/.test(d)) flags.push("description mentions a refund/reversal");
  if (/\bpartial\b/.test(d)) flags.push("description mentions a partial payment");
  if (amount === 0) flags.push("zero amount — check for a data entry error");
  return flags;
}

export function suggestCategory(input: { vendor?: string | null; description?: string | null; amount: number }): CategorySuggestion {
  const vendor = (input.vendor ?? "").trim();
  const description = (input.description ?? "").trim();
  const haystack = `${vendor} ${description}`.toLowerCase().trim();
  const flags = ambiguitySignals(description, input.amount);

  if (!haystack) {
    return { category: "Other", confidence: "low", reason: "No vendor or description text to go on — needs a human to categorize." };
  }

  for (const rule of RULES) {
    for (const pattern of rule.patterns) {
      if (pattern.test(haystack)) {
        const base = `Matched "${vendor || description}" to ${rule.category}`;
        if (flags.length > 0) {
          // A vendor match doesn't override a refund/partial-payment flag — still worth a second look.
          return { category: rule.category, confidence: "medium", reason: `${base}, but ${flags.join("; ")}.` };
        }
        return { category: rule.category, confidence: rule.confidence, reason: base };
      }
    }
  }

  if (flags.length > 0) {
    return { category: "Other", confidence: "low", reason: `No vendor pattern matched, and ${flags.join("; ")}.` };
  }

  // Generic/ambiguous text like "Payment #4521" or a person's name with no other context.
  return { category: "Other", confidence: "low", reason: "No confident match — vendor/description too generic." };
}
