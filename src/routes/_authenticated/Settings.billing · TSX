import { createFileRoute } from "@tanstack/react-router";
import { useEffect, useMemo, useState } from "react";
import { supabase } from "@/integrations/supabase/client";
import { Button } from "@/components/ui/button";
import { Badge } from "@/components/ui/badge";
import { Card, CardContent, CardHeader } from "@/components/ui/card";
import { Switch } from "@/components/ui/switch";
import { Table, TableBody, TableCell, TableHead, TableHeader, TableRow } from "@/components/ui/table";
import {
  Check, X, Sparkles, ShieldCheck, Lock, RefreshCw, Download, CreditCard,
} from "lucide-react";
import { toast } from "sonner";

export const Route = createFileRoute("/_authenticated/settings/billing")({
  head: () => ({ meta: [{ title: "Upgrade plan — Free Accounting" }] }),
  component: BillingPage,
});

type PlanId = "starter" | "business" | "growth" | "enterprise";
type Interval = "monthly" | "annual";

type Plan = {
  id: PlanId;
  name: string;
  tagline: string;
  audience: string;
  monthly: number | null; // null = custom pricing
  annual: number | null;
  highlight?: boolean;
  features: string[];
  notIncluded?: string[];
};

const PLANS: Plan[] = [
  {
    id: "starter",
    name: "Starter",
    tagline: "Free forever",
    audience: "Freelancers, consultants, solopreneurs, students, side businesses",
    monthly: 0,
    annual: 0,
    features: [
      "1 company, 1 user", "Unlimited clients & suppliers", "Unlimited invoices & quotations",
      "Unlimited expenses & income records", "Dashboard & basic reports", "AI Bookkeeping (limited)",
      "Multi-currency", "Tax settings", "Bank accounts", "Attachments", "Mobile responsive",
    ],
    notIncluded: ["Warehouses & inventory", "Payroll", "Projects", "Purchase orders", "User permissions", "Audit logs", "API"],
  },
  {
    id: "business",
    name: "Business",
    tagline: "$19/month",
    audience: "SMEs, shops, restaurants, agencies, clinics",
    monthly: 19,
    annual: 190,
    highlight: true,
    features: [
      "Everything in Starter", "3 companies, up to 10 users", "Stock, warehouses & low-stock alerts",
      "Stock transfers & adjustments", "Purchase orders", "Recurring invoices & credit notes",
      "Customer statements", "Expense categories & vendor bills", "P&L, balance sheet, cash flow, VAT reports",
      "User roles & permissions", "Unlimited AI categorization", "100 GB storage",
    ],
  },
  {
    id: "growth",
    name: "Growth",
    tagline: "$49/month",
    audience: "Growing companies ready to scale",
    monthly: 49,
    annual: 490,
    features: [
      "Everything in Business", "Unlimited companies & users", "Budgeting, journal entries, fixed assets & depreciation",
      "Unlimited warehouses, batch tracking & barcodes", "Payroll, leave & payslips", "Customer pipeline & follow-ups",
      "Time tracking & project costing", "AI Bookkeeper, insights, forecasting & reports",
      "Email automation & invoice reminders", "API, Zapier & webhooks", "1 TB storage",
    ],
  },
  {
    id: "enterprise",
    name: "Enterprise",
    tagline: "Custom pricing",
    audience: "NGOs, governments, universities, banks, large organizations",
    monthly: null,
    annual: null,
    features: [
      "Everything in Growth", "Unlimited storage", "Dedicated database", "SSO & Active Directory",
      "Audit logs & advanced security", "Custom modules & integrations", "Dedicated account manager",
      "Priority support & SLA", "White label", "On-premise deployment", "Custom branding",
    ],
  },
];

const COMPARISON_ROWS: { label: string; values: [string, string, string, string] }[] = [
  { label: "Companies", values: ["1", "3", "Unlimited", "Unlimited"] },
  { label: "Users", values: ["1", "10", "Unlimited", "Unlimited"] },
  { label: "Clients / suppliers", values: ["Unlimited", "Unlimited", "Unlimited", "Unlimited"] },
  { label: "Invoices / quotes / expenses", values: ["Unlimited", "Unlimited", "Unlimited", "Unlimited"] },
  { label: "Inventory & warehouses", values: ["—", "✓ (5 warehouses)", "✓ Unlimited", "✓ Unlimited"] },
  { label: "Payroll", values: ["—", "—", "✓", "✓"] },
  { label: "Projects", values: ["—", "—", "✓", "✓"] },
  { label: "AI Bookkeeping", values: ["Limited", "Full", "Advanced", "Premium"] },
  { label: "API access", values: ["—", "—", "✓", "✓"] },
  { label: "Audit logs", values: ["—", "—", "✓", "✓"] },
  { label: "Team permissions", values: ["—", "✓", "✓", "✓"] },
  { label: "Storage", values: ["5 GB", "100 GB", "1 TB", "Unlimited"] },
  { label: "Support", values: ["Community", "Email", "Priority", "Dedicated"] },
];

const TRUST_BADGES = [
  { icon: ShieldCheck, label: "Bank-grade encryption (AES-256 + TLS)" },
  { icon: Lock, label: "GDPR-ready data handling" },
  { icon: RefreshCw, label: "Automatic daily backups" },
  { icon: Download, label: "Free data export, any time" },
];

function fmtPrice(n: number | null, interval: Interval) {
  if (n === null) return "Custom";
  if (n === 0) return "Free";
  return interval === "monthly" ? `$${n}/mo` : `$${n}/yr`;
}

function BillingPage() {
  const [currentPlan, setCurrentPlan] = useState<PlanId>("starter");
  const [interval, setInterval] = useState<Interval>("monthly");
  const [loading, setLoading] = useState(true);
  const [saving, setSaving] = useState<PlanId | null>(null);

  useEffect(() => {
    (async () => {
      const { data: u } = await supabase.auth.getUser();
      if (!u.user) return setLoading(false);
      const { data } = await (supabase as any).from("profiles").select("plan,billing_interval").eq("id", u.user.id).maybeSingle();
      if (data) {
        setCurrentPlan((data.plan as PlanId) || "starter");
        setInterval((data.billing_interval as Interval) || "monthly");
      }
      setLoading(false);
    })();
  }, []);

  const planRank = useMemo(() => ({ starter: 0, business: 1, growth: 2, enterprise: 3 }), []);

  async function selectPlan(plan: Plan) {
    if (plan.id === currentPlan) return;
    if (plan.id === "enterprise") {
      window.location.href = "mailto:sales@careerliftglobal.com?subject=Enterprise%20plan%20inquiry";
      return;
    }
    const { data: u } = await supabase.auth.getUser();
    if (!u.user) return toast.error("You need to be signed in to change plans.");
    setSaving(plan.id);
    const { error } = await (supabase as any)
      .from("profiles")
      .update({ plan: plan.id, billing_interval: interval, plan_updated_at: new Date().toISOString() })
      .eq("id", u.user.id);
    setSaving(null);
    if (error) return toast.error(error.message);
    setCurrentPlan(plan.id);
    const isUpgrade = planRank[plan.id] > planRank[currentPlan];
    toast.success(
      plan.id === "starter"
        ? "Moved back to the Starter plan."
        : `${isUpgrade ? "Upgraded" : "Switched"} to ${plan.name}. Billing isn't connected yet, so you won't be charged — this just saves your plan preference.`,
    );
  }

  return (
    <div>
      <div className="mb-6">
        <h1 className="text-3xl font-bold">Upgrade your plan</h1>
        <p className="text-muted-foreground">Pick the plan that matches how your business runs today — upgrade any time as you grow.</p>
      </div>

      <div className="flex items-center justify-center gap-3 mb-8">
        <span className={`text-sm ${interval === "monthly" ? "font-semibold" : "text-muted-foreground"}`}>Monthly</span>
        <Switch checked={interval === "annual"} onCheckedChange={(v) => setInterval(v ? "annual" : "monthly")} />
        <span className={`text-sm ${interval === "annual" ? "font-semibold" : "text-muted-foreground"}`}>
          Annual <Badge variant="secondary" className="ml-1">2 months free</Badge>
        </span>
      </div>

      <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-10">
        {PLANS.map((plan) => {
          const isCurrent = plan.id === currentPlan;
          const price = fmtPrice(interval === "monthly" ? plan.monthly : plan.annual, interval);
          return (
            <Card key={plan.id} className={plan.highlight ? "border-primary shadow-lg relative" : "relative"}>
              {plan.highlight && (
                <Badge className="absolute -top-2.5 left-1/2 -translate-x-1/2 gap-1"><Sparkles className="h-3 w-3" /> Most popular</Badge>
              )}
              <CardHeader className="pb-2">
                <div className="flex items-center justify-between">
                  <h3 className="text-lg font-bold">{plan.name}</h3>
                  {isCurrent && <Badge variant="outline">Current plan</Badge>}
                </div>
                <p className="text-xs text-muted-foreground">{plan.audience}</p>
                <div className="text-2xl font-bold mt-2">{price}</div>
              </CardHeader>
              <CardContent className="space-y-3">
                <Button
                  className={`w-full ${plan.highlight ? "bg-gradient-hero" : ""}`}
                  variant={plan.highlight ? "default" : "outline"}
                  disabled={isCurrent || saving === plan.id || loading}
                  onClick={() => selectPlan(plan)}
                >
                  {saving === plan.id ? "Saving…" : isCurrent ? "Current plan" : plan.id === "enterprise" ? "Contact sales" : plan.id === "starter" ? "Downgrade" : "Upgrade"}
                </Button>
                <ul className="space-y-1.5 text-sm">
                  {plan.features.map((f) => (
                    <li key={f} className="flex items-start gap-2">
                      <Check className="h-4 w-4 text-emerald-600 shrink-0 mt-0.5" /> <span>{f}</span>
                    </li>
                  ))}
                  {plan.notIncluded?.map((f) => (
                    <li key={f} className="flex items-start gap-2 text-muted-foreground">
                      <X className="h-4 w-4 shrink-0 mt-0.5" /> <span>{f}</span>
                    </li>
                  ))}
                </ul>
              </CardContent>
            </Card>
          );
        })}
      </div>

      <div className="mb-10">
        <h2 className="text-xl font-bold mb-4">Feature comparison</h2>
        <div className="bg-card border rounded-xl overflow-x-auto">
          <Table>
            <TableHeader>
              <TableRow>
                <TableHead>Feature</TableHead>
                {PLANS.map((p) => <TableHead key={p.id} className="text-center">{p.name}</TableHead>)}
              </TableRow>
            </TableHeader>
            <TableBody>
              {COMPARISON_ROWS.map((row) => (
                <TableRow key={row.label}>
                  <TableCell className="font-medium">{row.label}</TableCell>
                  {row.values.map((v, i) => <TableCell key={i} className="text-center text-sm">{v}</TableCell>)}
                </TableRow>
              ))}
            </TableBody>
          </Table>
        </div>
      </div>

      <div className="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-6">
        {TRUST_BADGES.map((b) => (
          <div key={b.label} className="flex items-start gap-2 text-sm text-muted-foreground">
            <b.icon className="h-4 w-4 text-primary shrink-0 mt-0.5" /> <span>{b.label}</span>
          </div>
        ))}
      </div>

      <div className="flex items-center gap-2 text-xs text-muted-foreground bg-muted/50 border rounded-lg p-3">
        <CreditCard className="h-4 w-4 shrink-0" />
        Payment processing isn't connected yet — selecting a plan here saves your preference and won't charge a card.
        We'll email you when billing goes live.
      </div>
    </div>
  );
}
