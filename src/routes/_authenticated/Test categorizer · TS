import { suggestCategory } from "../src/lib/categorize-rules";

type Case = {
  vendor: string | null;
  description: string | null;
  amount: number;
  currency: string;
  expected: string; // human-judged correct category, or "REVIEW" if it should NOT be auto-categorized
  note: string;
};

const cases: Case[] = [
  { vendor: "Amazon Web Services", description: "Monthly hosting bill", amount: 84.20, currency: "USD", expected: "Software", note: "Clear SaaS vendor" },
  { vendor: "Uber", description: "Ride to client meeting", amount: 12.50, currency: "USD", expected: "Travel", note: "Clear rideshare" },
  { vendor: "Rwanda Energy Group", description: "REG electricity bill - July", amount: 145000, currency: "RWF", expected: "Utilities", note: "Local utility, non-USD currency" },
  { vendor: "MTN Rwanda", description: "Office internet bundle", amount: 60000, currency: "RWF", expected: "Utilities", note: "Local telco, non-USD currency" },
  { vendor: "Kigali Marriott Hotel", description: "Client visit accommodation", amount: 220, currency: "USD", expected: "Travel", note: "Hotel stay" },
  { vendor: "Java House", description: "Team coffee meeting", amount: 18, currency: "USD", expected: "Meals", note: "Local cafe chain" },
  { vendor: "Upwork", description: "Freelance designer payment", amount: 300, currency: "USD", expected: "Professional Services", note: "Freelance platform" },
  { vendor: "Facebook", description: "Ads campaign - July promo", amount: 75, currency: "USD", expected: "Marketing", note: "Ad platform" },
  { vendor: null, description: "Office rent - July", amount: 500, currency: "USD", expected: "Rent", note: "No vendor, description carries signal" },
  { vendor: "CareerLift Payroll", description: "Staff salaries - July batch", amount: 4200, currency: "USD", expected: "Payroll", note: "Payroll batch" },
  { vendor: "Best Buy", description: "New laptop for design team", amount: 1200, currency: "USD", expected: "Equipment", note: "Hardware purchase" },
  { vendor: "Certa Law Chambers", description: "Contract review legal fees", amount: 350, currency: "USD", expected: "Professional Services", note: "Legal services" },
  { vendor: "Jumia", description: "Refund - returned printer cartridge", amount: -45, currency: "USD", expected: "REVIEW", note: "Negative amount / refund — should be flagged, not silently filed" },
  { vendor: "Zoom", description: "Annual subscription renewal", amount: 149.90, currency: "USD", expected: "Software", note: "SaaS renewal" },
  { vendor: "John K.", description: "Payment #4521", amount: 90, currency: "USD", expected: "REVIEW", note: "Fully generic, no real signal" },
  { vendor: "Unknown Vendor Ltd", description: "", amount: 60, currency: "USD", expected: "REVIEW", note: "No description at all" },
  { vendor: "Bank of Kigali", description: "Loan interest partial payment", amount: 200, currency: "USD", expected: "REVIEW", note: "Partial payment — ambiguous, not a normal expense category" },
  { vendor: "Client Refund Co", description: "Reversal of duplicate charge", amount: -120, currency: "USD", expected: "REVIEW", note: "Explicit reversal wording" },
  { vendor: "Total Energies", description: "Fuel for delivery van", amount: 80, currency: "USD", expected: "Travel", note: "Fuel purchase" },
  { vendor: "Boda rider", description: "Moto fare - document delivery", amount: 2, currency: "USD", expected: "Travel", note: "East African moto-taxi slang" },
  { vendor: "Canva", description: "Pro plan monthly", amount: 15, currency: "USD", expected: "Software", note: "Design SaaS" },
  { vendor: "", description: "", amount: 0, currency: "USD", expected: "REVIEW", note: "Completely empty + zero amount edge case" },
];

let correct = 0;
let correctlyFlaggedForReview = 0;
let wrong = 0;
const rows: string[] = [];

for (const c of cases) {
  const result = suggestCategory({ vendor: c.vendor, description: c.description, amount: c.amount });
  const shouldBeReview = c.expected === "REVIEW";
  const gotFlaggedLow = result.confidence === "low" || result.confidence === "medium";
  let verdict: string;

  if (shouldBeReview) {
    if (gotFlaggedLow) { correctlyFlaggedForReview++; verdict = "PASS (correctly not high-confidence)"; }
    else { wrong++; verdict = "FAIL (should have been flagged, but got high confidence)"; }
  } else {
    if (result.category === c.expected) { correct++; verdict = `PASS (${result.confidence})`; }
    else { wrong++; verdict = `FAIL (got ${result.category}, expected ${c.expected})`; }
  }

  rows.push(
    `${verdict.padEnd(45)} | ${(c.vendor || "(none)").padEnd(24)} | ${(c.description || "(none)").slice(0, 32).padEnd(32)} | ${c.currency} ${c.amount.toString().padEnd(8)} | -> ${result.category} [${result.confidence}] :: ${result.reason}`,
  );
}

console.log(rows.join("\n"));
console.log("\n--- SUMMARY ---");
console.log(`Total cases: ${cases.length}`);
console.log(`Correctly categorized (non-review cases): ${correct} / ${cases.length - cases.filter(c => c.expected === "REVIEW").length}`);
console.log(`Correctly held back for review (ambiguous/refund/generic cases): ${correctlyFlaggedForReview} / ${cases.filter(c => c.expected === "REVIEW").length}`);
console.log(`Wrong: ${wrong}`);
